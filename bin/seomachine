#!/usr/bin/env python3
"""
SeoMachine — Hermes Agent SEO 搜索引擎优化 CLI 工具
基于 TheCraigHewitt/seomachine 项目适配

用法:
  seomachine research <topic>              — 关键词与竞争对手研究
  seomachine write <topic>                 — 创建 SEO 优化文章
  seomachine optimize <file>               — SEO 优化文章
  seomachine analyze <url>                 — 页面 SEO 健康检查
  seomachine keywords <topic>              — 关键词研究与建议
  seomachine cluster <topic>               — 主题集群策略
  seomachine score <file>                  — 内容质量评分
  seomachine audit <file>                  — 全面 SEO 审计
  seomachine list-commands                 — 列出所有子命令
  seomachine help [command]                — 查看帮助
"""

import sys
import os
import json
import importlib.util

ROOT_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, ROOT_DIR)
sys.path.insert(0, os.path.join(ROOT_DIR, 'data_sources', 'modules'))

def load_data_modules():
    modules = {}
    module_dir = os.path.join(ROOT_DIR, 'data_sources', 'modules')
    for mname in ['seo_quality_rater', 'readability_scorer', 'keyword_analyzer', 'content_scorer', 'search_intent_analyzer', 'content_length_comparator', 'opportunity_scorer']:
        mpath = os.path.join(module_dir, f'{mname}.py')
        if os.path.exists(mpath):
            spec = importlib.util.spec_from_file_location(mname, mpath)
            mod = importlib.util.module_from_spec(spec)
            try:
                spec.loader.exec_module(mod)
                modules[mname] = mod
            except Exception:
                pass
    return modules

def cmd_research(args):
    """关键词与竞争对手研究"""
    if not args:
        return {"error": "请提供研究主题", "usage": "seomachine research <topic>"}
    topic = ' '.join(args)
    script = os.path.join(ROOT_DIR, 'research_quick_wins.py')
    if os.path.exists(script):
        return {"topic": topic, "script_available": True, "note": f"运行: python3 {script} --topic '{topic}'"}
    return {"topic": topic, "status": "no_script"}

def cmd_write(args):
    """创建 SEO 优化文章"""
    if not args:
        return {"error": "请提供文章主题", "usage": "seomachine write <topic>"}
    topic = ' '.join(args)
    modules = load_data_modules()
    guidance = {}
    if 'seo_quality_rater' in modules:
        rater = modules['seo_quality_rater'].SEOQualityRater()
        guidance["seo_guidelines"] = rater._default_guidelines()
    if 'search_intent_analyzer' in modules:
        try:
            intent = modules['search_intent_analyzer'].SearchIntentAnalyzer()
            guidance["search_intent"] = intent.analyze(topic)
        except Exception:
            guidance["search_intent"] = {"assessment": "无法自动分析"}
    return {
        "topic": topic,
        "guidance": guidance,
        "suggested_h1": topic,
        "suggested_h2s": [f"什么是{topic}", f"{topic}的核心优势", f"如何开始使用{topic}", f"{topic}最佳实践", f"{topic}常见问题"],
        "suggested_meta": f"深入了解{topic}，从入门到精通。涵盖{topic}的核心概念、最佳实践和实用技巧。",
    }

def cmd_analyze(args):
    """页面 SEO 健康检查"""
    return {"target": ' '.join(args) if args else "(stdin)", "analyzers": list(load_data_modules().keys()), "message": "可执行 SEO 健康分析"}

def cmd_keywords(args):
    """关键词研究与建议"""
    if not args:
        return {"error": "请提供关键词", "usage": "seomachine keywords <keyword>"}
    keyword = ' '.join(args)
    modules = load_data_modules()
    result = {"keyword": keyword}
    if 'search_intent_analyzer' in modules:
        try:
            result["search_intent"] = modules['search_intent_analyzer'].SearchIntentAnalyzer().analyze(keyword)
        except Exception:
            result["search_intent"] = {"assessment": "无法分析"}
    if 'keyword_analyzer' in modules:
        result["analyzer_ready"] = True
    return result

def cmd_score(args):
    """内容质量评分（0-100）"""
    if not args:
        return {"error": "请提供文件路径", "usage": "seomachine score <file>"}
    filepath = ' '.join(args)
    if not os.path.exists(filepath):
        return {"error": f"文件不存在: {filepath}"}
    with open(filepath, 'r', encoding='utf-8') as f:
        content = f.read()
    result = {"file": filepath, "stats": {"char_count": len(content), "word_count": len(content.split())}}
    modules = load_data_modules()
    if 'content_scorer' in modules:
        try:
            score_inst = modules['content_scorer'].ContentScorer()
            score_result = score_inst.score(content)
            result["score"] = score_result
        except Exception as e:
            result["error"] = str(e)
    return result

def cmd_cluster(args):
    """主题集群策略"""
    if not args:
        return {"error": "请提供主题", "usage": "seomachine cluster <topic>"}
    topic = ' '.join(args)
    return {"topic": topic, "script": os.path.join(ROOT_DIR, 'research_topic_clusters.py')}

def cmd_audit(args):
    """全面 SEO 审计"""
    if not args:
        return {"error": "请提供文件路径或 URL", "usage": "seomachine audit <file|url>"}
    return {"target": ' '.join(args), "modules_loaded": list(load_data_modules().keys())}

COMMANDS = {
    "research": cmd_research, "write": cmd_write, "analyze": cmd_analyze,
    "keywords": cmd_keywords, "score": cmd_score, "cluster": cmd_cluster, "audit": cmd_audit,
}

def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        print(__doc__.strip())
        sys.exit(0)
    if sys.argv[1] == "list-commands":
        print("可用命令:")
        for cmd, fn in COMMANDS.items():
            doc = fn.__doc__ or fn.__name__.replace("cmd_", "").capitalize()
            print(f"  seomachine {cmd:<12} — {doc}")
        sys.exit(0)
    command = sys.argv[1]
    if command not in COMMANDS:
        print(json.dumps({"error": f"未知命令: {command}", "available": list(COMMANDS.keys())}, ensure_ascii=False))
        sys.exit(1)
    try:
        result = COMMANDS[command](sys.argv[2:])
        print(json.dumps(result, ensure_ascii=False, indent=2))
    except Exception as e:
        print(json.dumps({"error": str(e)}, ensure_ascii=False))
        sys.exit(1)

if __name__ == "__main__":
    main()
